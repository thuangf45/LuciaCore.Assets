{
  "system": {
    "version": "2.2.1",
    "debug": true,
    "versionCheckInterval": 2000,
    "sw": {
      "enabled": true,
      "path": "luciacore.sw",
      "cacheExtensions": [
        ".html",
        ".js",
        ".css",
        ".json",
        ".svg",
        ".png",
        ".jpg",
        ".jpeg"
      ]
    }
