            "children": [
              {
                "type": "props:center"
              }
            ]
          },
          {
            "type": "row",
            "children": [
              {
                "type": "props:bottom"
              }
            ]
          }
        ]
      }
    },
    {
      "type": "row_center",
      "layout": {
        "type": "row3",
        "props": {
