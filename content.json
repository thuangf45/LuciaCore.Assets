            "content": "template_footer"
          },
          "pageContent": [
            {
              "type": "custom_product_detail_section",
              "content": "product_detail_content",
              "api": "/assets/data/products.json?filter=id=props:id"
            }
          ]
        }
      }
    },
    {
      "name": "offline",
      "loading": "loading",
      "layout": {
