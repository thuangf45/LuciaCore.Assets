            "children": [
              {
                "type": "props:left"
              }
            ]
          },
          {
            "type": "row",
            "style": "flex: 1; justify-content: center;  min-width: 0;",
            "children": [
              {
                "type": "props:center"
              }
            ]
          },
          {
            "type": "row",
            "style": "flex:1; justify-content: flex-end; min-width: 0;",
            "children": [
              {
                "type": "props:right"
              }
            ]
          }
        ]
      }
    },
    {
      "type": "column3",
      "layout": {
        "type": "column",
        "style": "props:style;",
        "children": [
